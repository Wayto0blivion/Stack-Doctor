# Project-scoped signing/publishing secrets for Stack Doctor.
#
# Copy this file to ".env" (which is gitignored) and fill in the values. build.gradle.kts reads
# these as a fallback when the matching OS environment variable is not set, so `./gradlew signPlugin`
# picks them up automatically with no global env vars and nothing committed.
#
#   cp .env.example .env      # then edit .env
#
# Reuse the SAME key + certificate for every update (a new cert breaks Marketplace continuity).

# Absolute path to the certificate chain (.crt).
CERTIFICATE_CHAIN_FILE=C:\Users\Dustin\stackdoctor-signing\chain.crt

# Absolute path to the encrypted private key (.pem).
PRIVATE_KEY_FILE=C:\Users\Dustin\stackdoctor-signing\private.pem

# The private key's passphrase (from your password manager). Quote it if it contains spaces.
PRIVATE_KEY_PASSWORD=

# Marketplace upload token (only needed for ./gradlew publishPlugin). Leave blank for sign-only.
PUBLISH_TOKEN=
